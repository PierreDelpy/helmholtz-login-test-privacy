# Local URL where the app is reachable from your browser
BASE_URL=http://localhost:8080

# Keep this path because the app is exposed below /logintest
ROOT_PATH=/logintest

# Use the dev issuer first. Switch to production only after registration/approval.
OIDC_ISSUER=https://login-dev.helmholtz.de/oauth2

# Fill these after registering your OIDC client in Helmholtz ID
OIDC_CLIENT_ID=Login Test CCE Localhost
OIDC_CLIENT_SECRET=b23aCKtmSBEzZd

# Replace with a random secret string
SESSION_SECRET=skjdfhlklkppa

# Ask only for the scopes you want to inspect in the prototype
OIDC_SCOPE=openid profile email eduperson_scoped_affiliation org_domain
